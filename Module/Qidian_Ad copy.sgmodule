#!name=起点读书净化 (2026终极修复版)
#!desc=彻底修复：书架顶栏(每日导读/领福利)、底栏(猜你喜欢)、“我的”页面精简、开屏广告及配置开关。
#!author=Gemini-Adaptive
#!date=2026-03-02

[Script]
# 涵盖配置、书架刷新、每日推荐、用户中心及工具栏
qidian-purify = type=http-response,pattern=^https:\/\/magev6\.if\.qidian\.com\/argus\/api\/(v\d\/client\/getconf|v\d\/bookshelf\/(refresh|getBookshelf)|v\d\/dailyrecommend\/getdailyrecommend|v\d\/user\/getaccountpage|v\d\/client\/getsplashscreen|v\d\/assembly\/toolbar|v\d\/bookshelf\/getHoverAdv),requires-body=1,max-size=0,script-path=qidian_purify.js

[Map Local]
# 静态屏蔽广告与热词
^https:\/\/magev6\.if\.qidian\.com\/argus\/api\/v\d\/push\/getdialog data-type=text data="{}" status-code=200 header="Content-Type:application/json"
^https:\/\/magev6\.if\.qidian\.com\/argus\/api\/v\d\/booksearch\/hotWords data-type=text data="{}" status-code=200 header="Content-Type:application/json"

[MITM]
hostname = %APPEND% magev6.if.qidian.com, ywab.reader.qq.com