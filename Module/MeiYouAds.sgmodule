#!name=美柚去广告 Pro
#!desc=高性能优化版（减少冗余+降低误杀）
#!author=优化版
#!category=广告净化
#!ref=https://nssurge.com/llms.txt

[Rule]
# 核心广告域名（保留必要）
DOMAIN,ad.seeyouyima.com,REJECT
DOMAIN,ad-logs.seeyouyima.com,REJECT
DOMAIN,mgo.seeyouyima.com,REJECT
DOMAIN,jingqi.youzibuy.com,REJECT

# ⚠️ 不再直接拦 circle 主域


[URL Rewrite]
# 广告接口（精确拦截）
^https?:\/\/axxd\.xmseeyouyima\.com\/(ad|ad_statistics|getad|pregetad) - reject
^https?:\/\/common\.seeyouyima\.com\/v\d\/conf_list - reject
^http:\/\/x\.seeyouyima\.com\/adx\/staticstics\? - reject

# 圈子广告（替代直接 REJECT 域名）
^https?:\/\/circle\.xmseeyouyima\.com\/v\d\/feeds_recommend - reject


[Script]
# 合并逻辑（减少 jq）
美柚净化 = type=http-response, pattern=^https:\/\/config-service\.seeyouyima\.com\/api\/configs, script-path=https://raw.githubusercontent.com/fmz200/wool_scripts/main/Scripts/meiyou/meiyou_ads.js, requires-body=true, timeout=30


[MITM]
hostname = %APPEND% sub.seeyouyima.com, common.seeyouyima.com, users.seeyouyima.com, circle.xmseeyouyima.com, config-service.seeyouyima.com, x.seeyouyima.com, axxd.xmseeyouyima.com